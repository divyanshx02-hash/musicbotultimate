# ─── REQUIRED ──────────────────────────────────────────────────────────────
BOT_TOKEN=                     # From @BotFather
API_ID=                        # From https://my.telegram.org
API_HASH=                      # From https://my.telegram.org
STRING_SESSION=                # Assistant account 1 session string (run string_session_generator.py)
OWNER_ID=                      # Space-separated owner user IDs, e.g. "123456789 987654321"
LOGGER_ID=                     # Log channel or group ID (bot must be admin there)
MONGO_DB_URI=                  # MongoDB Atlas URI, e.g. mongodb+srv://user:pass@cluster.mongodb.net/
REDIS_URL=redis://localhost:6379  # Redis URL

# ─── OPTIONAL ASSISTANTS ───────────────────────────────────────────────────
STRING_SESSION2=               # Second assistant (for load balancing)
STRING_SESSION3=               # Third assistant

# ─── COOKIES ───────────────────────────────────────────────────────────────
COOKIE_URL=                    # Raw URL to cookies.txt (Pastebin raw URL, Batbin, etc.)

# ─── OPTIONAL PLATFORM APIs ────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=             # From https://developer.spotify.com
SPOTIFY_CLIENT_SECRET=
GENIUS_ACCESS_TOKEN=           # From https://genius.com/api-clients
DEEZER_ARL=                    # Deezer ARL cookie for FLAC quality
JIOSAAVN_COOKIE=               # JioSaavn auth cookie

# ─── SONG RECOGNITION ──────────────────────────────────────────────────────
ACRCLOUD_ACCESS_KEY=           # From https://console.acrcloud.com
ACRCLOUD_ACCESS_SECRET=
ACRCLOUD_HOST=                 # e.g. identify-eu-west-1.acrcloud.com

# ─── AI RECOMMENDATIONS ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=             # Preferred — from https://console.anthropic.com
OPENAI_API_KEY=                # Fallback — from https://platform.openai.com

# ─── EVENTS ────────────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=          # From https://developer.ticketmaster.com

# ─── FALLBACK DOWNLOAD APIs ────────────────────────────────────────────────
API_URL=                       # Optional yt-dlp fallback API endpoint
VIDEO_API_URL=                 # Optional video download fallback

# ─── LIMITS ────────────────────────────────────────────────────────────────
TG_AUDIO_FILESIZE_LIMIT=104857600   # 100MB
TG_VIDEO_FILESIZE_LIMIT=1073741824  # 1GB

# ─── BEHAVIOR ──────────────────────────────────────────────────────────────
PRIVATE_BOT_MODE=False              # True = owner groups only
AUTO_LEAVING_ASSISTANT=True         # Auto-leave empty VC
ASSISTANT_LEAVE_TIME=300            # Seconds of silence before leaving VC
YOUTUBE_EDIT_SLEEP=3
TELEGRAM_EDIT_SLEEP=5

# ─── MINI APP ──────────────────────────────────────────────────────────────
WEBAPP_URL=                    # URL of your deployed Mini App (e.g. https://youruser.github.io/musicbot-app)
